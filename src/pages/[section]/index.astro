---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { getSections, getSectionLabel, getSectionDescription, isConventionSection, isDateSection } from '../../lib/sections';

export async function getStaticPaths() {
  const all = await getCollection('articles');
  const sectionSlugs = getSections(all);

  return sectionSlugs.map(section => ({
    params: { section },
    props: {
      articles: all
        .filter(a => a.id.startsWith(`${section}/`))
        .sort((a, b) => a.data.date.getTime() - b.data.date.getTime()),
    },
  }));
}

const { section } = Astro.params;
const { articles } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const title = getSectionLabel(section);
const desc = getSectionDescription(section);
const groupLabel = isConventionSection(section) ? 'Convention' : isDateSection(section) ? 'Transition' : null;
---
<Base title={title}>
  <style>
    .section-page { padding: 40px 0 0; }

    .breadcrumb {
      font-size: 12px; font-weight: 600;
      color: var(--fg-muted); letter-spacing: 0.02em;
      margin-bottom: 20px;
      display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
    }
    .breadcrumb a { color: var(--fg-muted); text-decoration: none; }
    .breadcrumb a:hover { color: var(--signal-ink); }
    .breadcrumb .sep { color: var(--signal); font-weight: 800; }

    .section-head {
      padding: 8px 0 28px; border-bottom: 3px solid var(--ink);
      margin-bottom: 0; display: grid;
      grid-template-columns: 1fr auto; gap: 24px; align-items: end;
    }
    .section-head .title-block h1 {
      font-weight: 900;
      font-size: clamp(36px, 4.5vw, 52px);
      line-height: 0.98; letter-spacing: -0.03em; margin: 0 0 8px;
    }
    .section-head .title-block .sub {
      font-family: var(--font-mono); font-size: 12px;
      letter-spacing: 0.06em; color: var(--fg-muted); text-transform: uppercase;
    }
    .count-big {
      font-weight: 900; font-size: 48px; line-height: 1;
      color: var(--signal); letter-spacing: -0.03em;
      -webkit-text-stroke: 1.5px var(--ink);
    }
    .count-big small {
      display: block; -webkit-text-stroke: 0;
      font-size: 10px; font-weight: 800;
      letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--ink); margin-top: 6px;
    }

    .article-list { list-style: none; margin: 0; padding: 0; }
    .article-list > li {
      padding: 22px 0;
      border-bottom: 1.5px solid color-mix(in oklab, var(--ink) 18%, transparent);
      display: grid; grid-template-columns: 88px 1fr auto;
      gap: 20px; align-items: baseline;
    }
    .article-list > li:last-child { border-bottom: 0; }
    .article-list > li:hover .a-title a { color: var(--signal-ink); }

    .a-date {
      font-family: var(--font-mono); font-size: 11px;
      letter-spacing: 0.04em; color: var(--ink);
      font-weight: 500; padding-top: 4px;
    }
    .a-date .day {
      display: block; font-family: var(--font-body);
      font-weight: 900; font-size: 24px; line-height: 1;
      color: var(--ink); letter-spacing: -0.02em; margin-bottom: 2px;
    }
    .a-date .month {
      font-family: var(--font-body); font-weight: 700;
      font-size: 10px; letter-spacing: 0.18em;
      text-transform: uppercase; color: var(--signal-ink);
    }

    .a-title a {
      font-weight: 700; font-size: 18px;
      line-height: 1.25; letter-spacing: -0.01em;
      color: var(--ink); text-decoration: none;
    }
    .a-title a:hover {
      text-decoration: underline;
      text-decoration-color: var(--signal);
      text-decoration-thickness: 2px;
      text-underline-offset: 4px;
    }
    .a-meta {
      font-size: 12.5px; color: var(--fg-muted);
      margin-top: 4px; display: flex;
      flex-wrap: wrap; gap: 6px 12px; align-items: center;
    }
    .a-meta .outlet { font-weight: 700; color: var(--ink); }
    .a-meta .lang {
      font-family: var(--font-mono); font-size: 10px;
      letter-spacing: 0.1em; font-weight: 600;
      text-transform: uppercase;
      background: var(--cream-2); border: 1px solid var(--ink);
      color: var(--ink); padding: 2px 6px 1px; border-radius: 3px;
    }

    .a-tag {
      font-weight: 800; font-size: 10px;
      letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--ink); padding: 4px 10px 3px;
      border: 1.5px solid var(--ink); border-radius: 999px;
      background: var(--cream); line-height: 1;
      align-self: center; white-space: nowrap;
    }
    .a-tag.stub { background: var(--hope); border-color: var(--ink); }
    .a-tag.transcript { background: var(--ink); color: var(--cream); }
    .a-tag.speech { background: var(--movement); color: var(--cream); border-color: var(--movement); }
    .a-tag.statement { background: var(--signal); color: var(--ink); border-color: var(--signal); }

    @media (max-width: 820px) {
      .section-head { grid-template-columns: 1fr; }
      .article-list > li { grid-template-columns: 64px 1fr; }
      .a-tag { grid-column: 2; justify-self: start; margin-top: 4px; }
    }
  </style>

  <section class="section-page">
    <div class="container">
      <nav class="breadcrumb" data-pagefind-ignore>
        <a href={base}>Home</a>
        {groupLabel && (
          <>
            <span class="sep">→</span>
            <span>{groupLabel}</span>
          </>
        )}
        <span class="sep">→</span>
        <span>{title}</span>
      </nav>

      <div class="section-head">
        <div class="title-block">
          <h1>{title}</h1>
          {desc && <div class="sub">{desc}</div>}
        </div>
        <div class="count-big">{articles.length}<small>Items archived</small></div>
      </div>

      {articles.length === 0 ? (
        <p style="color: var(--fg-muted); font-style: italic; padding: 2rem 0;">No documents in this section yet.</p>
      ) : (
        <ul class="article-list">
          {articles.map(a => {
            const day = a.data.date.getUTCDate();
            const mon = a.data.date.toLocaleDateString('en-CA', { month: 'short', timeZone: 'UTC' });
            const lang = a.data.language ?? 'en';
            const [sectionSlug, ...rest] = a.id.split('/');
            const slug = rest.join('/');
            const href = `${base}${a.id}/`;

            let tagClass = '';
            let tagLabel = 'Article';
            if (a.data.stub) { tagClass = 'stub'; tagLabel = 'Stub'; }
            else if (a.data.type === 'transcript') { tagClass = 'transcript'; tagLabel = 'Transcript'; }
            else if (a.data.type === 'speech') { tagClass = 'speech'; tagLabel = 'Speech'; }
            else if (a.data.type === 'statement') { tagClass = 'statement'; tagLabel = 'Statement'; }

            return (
              <li>
                <div class="a-date">
                  <span class="day">{day}</span>
                  <span class="month">{mon} · {lang}</span>
                </div>
                <div class="a-title">
                  <a href={href}>{a.data.title}</a>
                  <div class="a-meta">
                    {a.data.outlet && <span class="outlet">{a.data.outlet}</span>}
                    {a.data.outlet && a.data.author && <span>·</span>}
                    {a.data.author && <span class="author">{a.data.author}</span>}
                    {lang !== 'en' && <span class="lang">{lang.toUpperCase()}</span>}
                  </div>
                </div>
                <span class={`a-tag ${tagClass}`}>{tagLabel}</span>
              </li>
            );
          })}
        </ul>
      )}
    </div>
  </section>
</Base>
